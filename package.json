{
  "name": "aero",
  "version": "1.0.0",
  "private": true,
  "description": "Aero — Secure. Protect. Recover. A personal device protection and management platform.",
  "author": "Md Arafat Hossen Mugdho (AFM Technologies)",
  "license": "MIT",
  "scripts": {
    "android": "react-native run-android",
    "start": "react-native start",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-native": "0.75.4",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "react-native-screens": "^3.34.0",
    "react-native-safe-area-context": "^4.11.0",
    "@reduxjs/toolkit": "^2.2.7",
    "react-redux": "^9.1.2",
    "@tanstack/react-query": "^5.56.2",
    "@react-native-async-storage/async-storage": "^2.0.0",
    "react-native-keychain": "^9.2.2",
    "@react-native-firebase/app": "^20.4.0",
    "@react-native-firebase/auth": "^20.4.0",
    "@react-native-firebase/firestore": "^20.4.0",
    "@react-native-firebase/messaging": "^20.4.0",
    "@react-native-firebase/storage": "^20.4.0",
    "@react-native-google-signin/google-signin": "^13.1.0",
    "react-native-vector-icons": "^10.2.0",
    "react-native-svg": "^15.6.0",
    "react-native-maps": "1.14.0",
    "@react-native-community/geolocation": "^3.3.0",
    "react-native-qrcode-svg": "^6.3.2",
    "crypto-js": "^4.2.0",
    "react-hook-form": "^7.53.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.4",
    "@babel/runtime": "^7.25.4",
    "@react-native/babel-preset": "0.75.4",
    "@react-native/eslint-config": "0.75.4",
    "@react-native/metro-config": "0.75.4",
    "@react-native/typescript-config": "0.75.4",
    "@types/react": "^18.3.3",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/crypto-js": "^4.2.2",
    "typescript": "5.4.5",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "jest": "^29.7.0",
    "@testing-library/react-native": "^12.7.2",
    "@testing-library/jest-native": "^5.4.3"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native"
    ],
    "rules": {
      "no-unused-vars": "off",
      "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
      "react-hooks/exhaustive-deps": "warn",
      "no-console": ["warn", { "allow": ["warn", "error"] }]
    }
  },
  "engines": {
    "node": ">=18"
  }
}
