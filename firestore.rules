rules_version = '2';

// Baseline Firestore security rules for Aero.
// Every document under users/{uid}/** is only readable/writable by that
// user. Deploy with: firebase deploy --only firestore:rules
// (requires the Firebase CLI and a firebase.json pointing at this file).

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
